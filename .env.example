# ============================================
# BOTHUB.cz — Environment Variables
# ============================================

# Database (TiDB Serverless)
DATABASE_URL=mysql://user:pass@host:4000/dbname?ssl={"rejectUnauthorized":true}

# Auth
JWT_SECRET=nejake-tajne-heslo-minimalne-32-znaku
ADMIN_EMAIL=admin@bothub.cz
ADMIN_PASSWORD_HASH=      # viz instrukce v do-italie .env.example
OWNER_OPEN_ID=

# AI (Google Gemini — zdarma na ai.google.dev)
GOOGLE_AI_API_KEY=

# Email (SMTP nebo SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@bothub.cz

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# SEO
VITE_GSC_VERIFICATION=    # Google Search Console verification code

# LeadOS integrace
LEADCONNECT_API_KEY=

# BotHub API (až bude api.bothub.cz live)
BOTHUB_API_KEY=
BOTHUB_API_URL=https://api.bothub.cz

NODE_ENV=development
